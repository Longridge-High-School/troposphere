generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Person {
  id String @id @default(uuid())

  firstName String
  lastName  String
  title     String
  staffCode String
  cohort    String
  type      String

  accountName String @unique
  email       String @unique

  source String

  memberships GroupMembership[]
  serviceIds  PersonServiceIds[]
}

model PersonServiceIds {
  id String @id @default(uuid())

  serviceKey String
  serviceId  String

  person   Person @relation(fields: [personId], references: [id])
  personId String
}

model Group {
  id String @id @default(uuid())

  name String

  source String

  memberships GroupMembership[]
}

model GroupMembership {
  id String @id @default(uuid())

  group    Group  @relation(fields: [groupId], references: [id])
  groupId  String
  person   Person @relation(fields: [personId], references: [id])
  personId String
}
