generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Person {
  id String @id @default(uuid())

  firstName String
  lastName  String
  title     String
  staffCode String
  cohort    String
  type      String

  accountName String
  email       String

  source String

  memberships GroupMembership[]
  serviceIds  PersonServiceIds[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PersonServiceIds {
  id String @id @default(uuid())

  serviceKey String
  serviceId  String

  person   Person @relation(fields: [personId], references: [id])
  personId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Group {
  id String @id @default(uuid())

  name String

  source String

  memberships GroupMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GroupMembership {
  id String @id @default(uuid())

  group    Group  @relation(fields: [groupId], references: [id])
  groupId  String
  person   Person @relation(fields: [personId], references: [id])
  personId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model APIKey {
  id String @id @default(uuid())

  key String @unique
  platform String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}